<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      margin: 22px 28px 28px 28px;
    }

    :root {
      --ink: #122033;
      --muted: #5f6b7d;
      --line: #d6dde8;
      --panel: #f7f9fc;
      --accent: #1d6f84;
      --accent-soft: #e3f2f6;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      direction: rtl;
      font-family: 'DejaVu Sans', Arial, sans-serif;
      color: var(--ink);
      line-height: 1.5;
      padding-bottom: 30px;
    }

    .hero {
      border: 1px solid var(--line);
      border-radius: 18px;
      padding: 20px 22px;
      background: linear-gradient(180deg, rgba(241, 247, 252, 0.96), rgba(255, 255, 255, 0.98));
      margin-bottom: 16px;
    }

    .brand-row {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-bottom: 10px;
    }

    .brand-col {
      display: table-cell;
      vertical-align: top;
    }

    .brand-col.main {
      width: 65%;
      padding-left: 12px;
    }

    .brand-col.side {
      width: 35%;
      text-align: left;
    }

    .logo {
      max-height: 72px;
      max-width: 180px;
      object-fit: contain;
    }

    .company-name {
      margin: 0 0 4px;
      font-size: 19px;
      font-weight: 800;
      line-height: 1.2;
    }

    .company-subtitle {
      margin: 0;
      color: var(--muted);
      font-size: 11px;
    }

    .title-row {
      display: flex;
      justify-content: space-between;
      gap: 12px;
      align-items: flex-end;
      margin-top: 14px;
    }

    h1 {
      margin: 0;
      font-size: 26px;
      line-height: 1.15;
      color: var(--ink);
      font-weight: 800;
    }

    .date-chip {
      display: inline-flex;
      align-items: center;
      border-radius: 999px;
      padding: 6px 10px;
      background: #fff;
      border: 1px solid var(--line);
      color: var(--muted);
      font-size: 11px;
      white-space: nowrap;
    }

    .meta-grid {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 10px;
      margin-top: 14px;
    }

    .meta-card {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: #fff;
      padding: 10px 12px;
      font-size: 11px;
    }

    .meta-label {
      display: block;
      color: var(--muted);
      margin-bottom: 4px;
      font-weight: 700;
    }

    .meta-value {
      color: var(--ink);
      font-weight: 700;
      white-space: pre-line;
    }

    .section {
      border: 1px solid var(--line);
      border-radius: 16px;
      overflow: hidden;
      background: #fff;
      margin-top: 14px;
    }

    .section-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 12px 16px;
      background: #f9fbfd;
      border-bottom: 1px solid var(--line);
    }

    .section-title {
      margin: 0;
      font-size: 14px;
      font-weight: 800;
    }

    .section-kicker {
      margin: 0;
      color: var(--accent);
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.04em;
    }

    .section-body {
      padding: 14px 16px 16px;
    }

    table {
      width: 100%;
      border-collapse: separate;
      border-spacing: 0;
      overflow: hidden;
      border-radius: 12px;
      border: 1px solid var(--line);
    }

    th, td {
      padding: 10px 12px;
      border-bottom: 1px solid #edf1f6;
      text-align: right;
      font-size: 11px;
      vertical-align: top;
    }

    th {
      background: var(--panel);
      color: var(--muted);
      font-weight: 700;
    }

    tr:last-child th,
    tr:last-child td {
      border-bottom: none;
    }

    .totals {
      margin-top: 12px;
      display: grid;
      gap: 8px;
    }

    .total-line {
      border: 1px solid var(--line);
      border-radius: 12px;
      background: var(--panel);
      padding: 10px 12px;
      font-size: 12px;
    }

    .total-line strong {
      color: var(--ink);
    }

    .payment {
      display: grid;
      gap: 8px;
    }

    .payment-row {
      border: 1px solid var(--line);
      border-radius: 12px;
      padding: 10px 12px;
      background: #fff;
      font-size: 11px;
    }

    .payment-label {
      display: block;
      color: var(--muted);
      font-weight: 700;
      margin-bottom: 3px;
    }
  </style>
</head>
<body>
  <%
    const issueDate = data.issueDate ? formatHebrewDate(data.issueDate) : '';
    const dueDate = data.dueDate ? formatHebrewDate(data.dueDate) : '';
    const itemRows = data.items || [];
  %>

  <div class="hero">
    <div class="brand-row">
      <div class="brand-col main">
        <% if (data.companyName) { %><h2 class="company-name"><%= data.companyName %></h2><% } %>
        <p class="company-subtitle">מסמך תשלום מעוצב, קריא ומוכן לשליחה ללקוח</p>
      </div>
      <div class="brand-col side">
        <% if (header.logoUrl) { %>
          <img src="<%= header.logoUrl %>" class="logo" alt="לוגו החברה" />
        <% } %>
      </div>
    </div>

    <div class="title-row">
      <h1>דרישת תשלום</h1>
      <span class="date-chip">הופק ב-<%= formatHebrewDate(header.date) %></span>
    </div>

    <div class="meta-grid">
      <% if (data.invoiceNumber) { %><div class="meta-card"><span class="meta-label">מספר דרישה</span><span class="meta-value"><%= data.invoiceNumber %></span></div><% } %>
      <% if (issueDate) { %><div class="meta-card"><span class="meta-label">תאריך הנפקה</span><span class="meta-value"><%= issueDate %></span></div><% } %>
      <% if (dueDate) { %><div class="meta-card"><span class="meta-label">תאריך יעד</span><span class="meta-value"><%= dueDate %></span></div><% } %>
      <% if (data.clientName) { %><div class="meta-card"><span class="meta-label">לקוח</span><span class="meta-value"><%= data.clientName %></span></div><% } %>
    </div>
  </div>

  <% if (data.items && data.items.length) { %>
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">פירוט פריטים</h2>
      </div>
      <div class="section-body">
        <table>
          <thead>
            <tr>
              <th>תיאור</th>
              <th>כמות</th>
              <th>מחיר ליחידה</th>
              <th>סה"כ</th>
            </tr>
          </thead>
          <tbody>
            <% data.items.forEach(item => { %>
              <tr>
                <td><%= item.description %></td>
                <td><%= item.quantity %></td>
                <td><%= item.unitPrice %></td>
                <td><%= item.total %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    </div>
  <% } %>

  <div class="section">
    <div class="section-header">
      <h2 class="section-title">סיכום תשלום</h2>
    </div>
    <div class="section-body">
      <div class="totals">
        <% if (typeof data.vat === 'number' && data.vat > 0) { %>
          <div class="total-line">סה"כ לפני מע"מ: <%= data.total %> ש"ח</div>
          <div class="total-line">מע"מ: <%= data.vat %> ש"ח</div>
          <div class="total-line"><strong>סה"כ לתשלום: <%= data.total + data.vat %> ש"ח</strong></div>
        <% } else if (typeof data.total === 'number') { %>
          <div class="total-line"><strong>סה"כ לתשלום: <%= data.total %> ש"ח</strong></div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (data.paymentDetails) { %>
    <% const pd = data.paymentDetails; %>
    <div class="section">
      <div class="section-header">
        <h2 class="section-title">פרטי תשלום</h2>
      </div>
      <div class="section-body">
        <div class="payment">
          <% if (pd.bankName) { %><div class="payment-row"><span class="payment-label">בנק</span><span><%= pd.bankName %></span></div><% } %>
          <% if (pd.accountOwner) { %><div class="payment-row"><span class="payment-label">בעל החשבון</span><span><%= pd.accountOwner %></span></div><% } %>
          <% if (pd.branchNumber) { %><div class="payment-row"><span class="payment-label">סניף</span><span><%= pd.branchNumber %></span></div><% } %>
          <% if (pd.accountNumber) { %><div class="payment-row"><span class="payment-label">מס' חשבון</span><span><%= pd.accountNumber %></span></div><% } %>
        </div>
      </div>
    </div>
  <% } %>
</body>
</html>
