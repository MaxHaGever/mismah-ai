<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <style>
    @page {
      margin: 24px 30px 34px 30px;
    }

    :root {
      --ink: #111827;
      --muted: #4b5563;
      --line: #cbd5e1;
      --soft: #f8fafc;
      --soft-line: #e2e8f0;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      direction: rtl;
      font-family: 'DejaVu Sans', Arial, sans-serif;
      color: var(--ink);
      background: #fff;
      line-height: 1.6;
      font-size: 12px;
      padding-bottom: 32px;
    }

    .document {
      position: relative;
    }

    .header {
      border-bottom: 1px solid var(--line);
      padding-bottom: 14px;
      margin-bottom: 18px;
    }

    .header-top {
      display: table;
      width: 100%;
      table-layout: fixed;
      margin-bottom: 10px;
    }

    .header-brand,
    .header-meta {
      display: table-cell;
      vertical-align: top;
    }

    .header-brand {
      width: 32%;
      text-align: left;
    }

    .header-meta {
      width: 68%;
    }

    .logo {
      max-width: 150px;
      max-height: 90px;
      object-fit: contain;
    }

    .company-name {
      margin: 0 0 4px;
      font-size: 18px;
      font-weight: 800;
      color: var(--ink);
    }

    .company-line {
      margin: 0;
      color: var(--muted);
      font-size: 10.5px;
      line-height: 1.7;
    }

    .report-title {
      margin: 10px 0 4px;
      font-size: 22px;
      font-weight: 800;
      text-align: center;
      color: var(--ink);
    }

    .report-subtitle {
      margin: 0;
      text-align: center;
      color: var(--muted);
      font-size: 10.5px;
    }

    .meta-table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 18px;
    }

    .meta-table th,
    .meta-table td {
      border: 1px solid var(--soft-line);
      padding: 7px 9px;
      text-align: right;
      vertical-align: top;
      font-size: 11.5px;
    }

    .meta-table th {
      width: 18%;
      background: var(--soft);
      color: var(--muted);
      font-weight: 700;
    }

    .section {
      margin-top: 18px;
      break-inside: avoid;
    }

    .section-title {
      margin: 0 0 8px;
      padding-bottom: 5px;
      border-bottom: 1px solid var(--line);
      font-size: 13px;
      font-weight: 800;
      color: var(--ink);
    }

    .text-block {
      margin: 0;
      white-space: pre-line;
      line-height: 1.85;
      color: var(--ink);
    }

    .boxed-text {
      border: 1px solid var(--soft-line);
      background: #fff;
      padding: 11px 12px;
    }

    .checklist {
      margin: 0;
      padding: 0 18px 0 0;
    }

    .checklist li {
      margin-bottom: 6px;
      line-height: 1.75;
    }

    .locations {
      display: grid;
      gap: 12px;
    }

    .location-card {
      border: 1px solid var(--soft-line);
      padding: 12px;
      break-inside: avoid;
      background: #fff;
    }

    .location-title {
      margin: 0 0 8px;
      font-size: 12px;
      font-weight: 800;
    }

    .location-layout {
      display: table;
      width: 100%;
      table-layout: fixed;
    }

    .location-copy,
    .location-image {
      display: table-cell;
      vertical-align: top;
    }

    .location-copy {
      width: 58%;
      padding-left: 12px;
    }

    .location-image {
      width: 42%;
    }

    .image-frame {
      border: 1px solid var(--soft-line);
      padding: 8px;
      text-align: center;
      background: #fff;
    }

    .leak-photo {
      display: block;
      width: 100%;
      max-height: 220px;
      object-fit: contain;
    }

    .caption {
      margin: 8px 0 0;
      text-align: right;
      font-size: 10px;
      color: var(--muted);
      white-space: pre-line;
    }

    .extra-images-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }

    .extra-image-card {
      border: 1px solid var(--soft-line);
      padding: 10px;
      break-inside: avoid;
      background: #fff;
    }

    .extra-image-title {
      margin: 0 0 8px;
      font-size: 11px;
      font-weight: 800;
    }

    .footer {
      position: fixed;
      bottom: 12px;
      left: 30px;
      right: 30px;
      border-top: 1px solid var(--line);
      padding-top: 6px;
      text-align: center;
      font-size: 9px;
      color: var(--muted);
      background: #fff;
    }
  </style>
</head>
<body>
  <%
    const resolvedReportDate = resolveReportDate(data.reportDate);
    const generatedOnDate = formatHebrewDate(header.date);
    const testTools = data.testTools || data.testMethods || [];
    const contactExperience = data.contactExprience || data.contactExperience || '';
    const recommendations = data.recommendations || [];
    const leakLocations = data.leakLocations || [];
    const uploadedImages = Array.isArray(optional.images) ? optional.images : [];
    const extraImages = uploadedImages.slice(leakLocations.length);
    const reportNumber = data.reportNumber || '';
    const apartmentNumber = data.apartmentNumber || '';
    const floor = data.floor || '';
    const inspectorName = data.performedBy || '';
    const inspectionPhone = data.contactNumber || data.companyPhone || '';
    const backgroundText = data.incidentBackground || data.overview || '';
    const findingsText = data.findingsSummary || '';
    const issueSource = data.issueSource || '';
  %>

  <div class="document">
    <div class="header">
      <div class="header-top">
        <div class="header-meta">
          <% if (data.companyName) { %>
            <h1 class="company-name"><%= data.companyName %></h1>
          <% } else { %>
            <h1 class="company-name">דו"ח איתור נזילה</h1>
          <% } %>
          <p class="company-line">
            <% if (data.companyId) { %>ח.פ <%= data.companyId %><% } %>
            <% if (data.companyAddress) { %><%= data.companyId ? ' | ' : '' %><%= data.companyAddress %><% } %>
            <% if (inspectionPhone) { %><%= (data.companyId || data.companyAddress) ? ' | ' : '' %>טל׳ <%= inspectionPhone %><% } %>
            <% if (data.companyEmail) { %><%= (data.companyId || data.companyAddress || inspectionPhone) ? ' | ' : '' %><%= data.companyEmail %><% } %>
            <% if (data.companyWebsite) { %><%= (data.companyId || data.companyAddress || inspectionPhone || data.companyEmail) ? ' | ' : '' %><%= data.companyWebsite %><% } %>
          </p>
        </div>
        <div class="header-brand">
          <% if (header.logoUrl) { %>
            <img src="<%= header.logoUrl %>" class="logo" alt="לוגו החברה" />
          <% } %>
        </div>
      </div>

      <h2 class="report-title">דו"ח איתור נזילה</h2>
      <p class="report-subtitle">מסמך בדיקה, ממצאים והמלצות להמשך טיפול</p>

      <table class="meta-table">
        <tbody>
          <tr>
            <th>שם הלקוח</th>
            <td><%= data.clientName || '-' %></td>
            <th>תאריך בדיקה</th>
            <td><%= resolvedReportDate %></td>
          </tr>
          <tr>
            <th>כתובת הנכס</th>
            <td><%= data.propertyAddress || '-' %></td>
            <th>מספר דו"ח</th>
            <td><%= reportNumber || '-' %></td>
          </tr>
          <tr>
            <th>סוג נכס</th>
            <td><%= data.propertyType || '-' %></td>
            <th>מבצע הבדיקה</th>
            <td><%= inspectorName || '-' %></td>
          </tr>
          <tr>
            <th>מספר דירה</th>
            <td><%= apartmentNumber || '-' %></td>
            <th>קומה</th>
            <td><%= floor || '-' %></td>
          </tr>
          <tr>
            <th>מספר רישיון</th>
            <td><%= data.licenseNumber || '-' %></td>
            <th>טלפון ליצירת קשר</th>
            <td><%= inspectionPhone || '-' %></td>
          </tr>
        </tbody>
      </table>
    </div>

    <% if (backgroundText) { %>
      <div class="section">
        <h2 class="section-title">רקע ותיאור המפגע</h2>
        <div class="boxed-text">
          <p class="text-block"><%= backgroundText %></p>
        </div>
      </div>
    <% } %>

    <% if (contactExperience) { %>
      <div class="section">
        <h2 class="section-title">פרטי בודק וניסיון מקצועי</h2>
        <p class="text-block"><%= contactExperience %></p>
      </div>
    <% } %>

    <% if (testTools.length) { %>
      <div class="section">
        <h2 class="section-title">שיטות בדיקה</h2>
        <ul class="checklist">
          <% testTools.forEach(tool => { %>
            <li><%= tool %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <% if (findingsText) { %>
      <div class="section">
        <h2 class="section-title">ממצאים</h2>
        <p class="text-block"><%= findingsText %></p>
      </div>
    <% } %>

    <% if (leakLocations.length) { %>
      <div class="section">
        <h2 class="section-title">מוקדי נזילה שתועדו בבדיקה</h2>
        <div class="locations">
          <% leakLocations.forEach((loc, idx) => { %>
            <div class="location-card">
              <h3 class="location-title"><%= idx + 1 %>. <%= loc.location || `מוקד ${idx + 1}` %></h3>
              <div class="location-layout">
                <div class="location-copy">
                  <p class="text-block"><%= loc.description || 'אין תיאור נוסף.' %></p>
                </div>
                <div class="location-image">
                  <% if (uploadedImages[idx]) { %>
                    <div class="image-frame">
                      <img src="<%= uploadedImages[idx].url %>" class="leak-photo" alt="תמונת מוקד נזילה <%= idx + 1 %>" />
                      <% if (uploadedImages[idx].description) { %>
                        <p class="caption"><%= uploadedImages[idx].description %></p>
                      <% } %>
                    </div>
                  <% } else { %>
                    <div class="image-frame">
                      <p class="caption" style="margin:0;">לא צורפה תמונה למוקד זה.</p>
                    </div>
                  <% } %>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (issueSource) { %>
      <div class="section">
        <h2 class="section-title">מקור התקלה</h2>
        <p class="text-block"><%= issueSource %></p>
      </div>
    <% } %>

    <% if (recommendations.length) { %>
      <div class="section">
        <h2 class="section-title">המלצות להמשך טיפול</h2>
        <ul class="checklist">
          <% recommendations.forEach(rec => { %>
            <li><%= rec %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <% if (extraImages.length) { %>
      <div class="section">
        <h2 class="section-title">תמונות נוספות מהבדיקה</h2>
        <div class="extra-images-grid">
          <% extraImages.forEach((img, idx) => { %>
            <div class="extra-image-card">
              <h3 class="extra-image-title">תמונה <%= leakLocations.length + idx + 1 %></h3>
              <div class="image-frame">
                <img src="<%= img.url %>" class="leak-photo" alt="תמונה נוספת <%= leakLocations.length + idx + 1 %>" />
                <% if (img.description) { %>
                  <p class="caption"><%= img.description %></p>
                <% } %>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    <% } %>

    <% if (data.additionalNotes) { %>
      <div class="section">
        <h2 class="section-title">הערות נוספות</h2>
        <p class="text-block"><%= data.additionalNotes %></p>
      </div>
    <% } %>

    <div class="footer">
      מסמך זה הופק לצורכי תיעוד מקצועי | הופק בתאריך <%= generatedOnDate %>
    </div>
  </div>
</body>
</html>
